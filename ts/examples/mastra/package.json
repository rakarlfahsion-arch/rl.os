{
  "name": "mastra-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Example project for Mastra",
  "main": "src/index.ts",
  "scripts": {
    "clean": "git clean -xdf node_modules",
    "start": "bun src/index.ts",
    "tool-router": "bun src/tool-router.ts",
    "smoke": "bun src/smoke.ts",
    "dev": "bun --watch src/index.ts",
    "cf:dev": "wrangler dev",
    "cf:dry-run": "wrangler deploy --dry-run --outdir dist-worker",
    "typecheck": "tsc --noEmit -p ./tsconfig.json && tsc --noEmit -p ./tsconfig.worker.json",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "composio",
    "example",
    "mastra"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai": "^4.0.7",
    "@composio/core": "workspace:*",
    "@composio/mastra": "workspace:*",
    "@mastra/core": "catalog:",
    "ai": "^6.0.219",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "^26.1.1",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
